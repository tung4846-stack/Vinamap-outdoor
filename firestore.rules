rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true; 
      
      match /data/{document=**} {
        allow read, write: if true;
      }
    }
    match /global_sub_accounts/{subId} {
      allow read, write: if true;
    }
  }
}
